# Copy to .env and fill in values, or run: bash generate-env.sh > .env

POSTGRES_USER=diploma_app
POSTGRES_PASSWORD=CHANGE_ME

RABBITMQ_USER=diploma_rmq
RABBITMQ_PASSWORD=CHANGE_ME

JWT_SECRET=CHANGE_ME
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=CHANGE_ME
REFRESH_TOKEN_EXPIRES_IN=7d

INTERNAL_SERVICE_KEY=CHANGE_ME

OPENAI_API_KEY=
OPENROUTER_API_KEY=
# Default model used when a user picks "OpenRouter" as their provider.
# litellm needs the "openrouter/" prefix; full slug list:
#   https://openrouter.ai/models. Common picks:
#     openrouter/anthropic/claude-sonnet-4.6  ($3/$15 per M, 1M ctx)
#     openrouter/anthropic/claude-opus-4.7    ($5/$25 per M, top quality)
#     openrouter/openai/gpt-5.4               ($2.50/$15 per M)
#     openrouter/openai/gpt-oss-120b:free     (free tier, 50/day)
OPENROUTER_MODEL=openrouter/anthropic/claude-sonnet-4.6
GOOGLE_TTS_API_KEY=

GROQ_API_KEY=

VITE_API_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Outgoing email (Brevo SMTP relay; leave empty in dev — service will
# log the would-be email instead of delivering it).
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
